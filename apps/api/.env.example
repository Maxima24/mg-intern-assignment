# ---- Server ----
NODE_ENV=development
PORT=4000
# Comma-separated allowed browser origins (the web app). Empty = allow all (dev only).
CORS_ORIGINS=http://localhost:3000

# ---- Database (Postgres) ----
DATABASE_URL=postgresql://mango:mango@localhost:5544/mango_esign?schema=public

# ---- Setu eSign ----
# provider=stub runs the entire flow with deterministic fakes — no credentials needed.
# Leave SETU_PROVIDER unset to auto-derive: 'live' when SETU_CLIENT_ID is present, else 'stub'.
SETU_PROVIDER=stub
SETU_BASE_URL=https://dg-sandbox.setu.co

# Required only when provider=live (obtained from the Setu Bridge dashboard):
SETU_CLIENT_ID=
SETU_CLIENT_SECRET=
SETU_PRODUCT_INSTANCE_ID=

# Shared secret Setu signs webhook payloads with (HMAC-SHA256). Stub mode bypasses verification.
SETU_WEBHOOK_SECRET=

# Stub realism knob: number of status polls before the mock signature reaches sign_complete.
SETU_STUB_POLLS=2

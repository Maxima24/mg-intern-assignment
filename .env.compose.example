# Copy to `.env` (repo root) on the VPS and fill in. docker compose reads it for
# variable substitution. This file is the template; `.env` is gitignored.

# Domain whose A record points at this VPS. Caddy auto-provisions TLS for it.
APP_DOMAIN=esign.yourdomain.in

# --- Postgres ---
POSTGRES_PASSWORD=change-me-to-a-strong-password

# --- Setu (from the Setu Bridge dashboard; VPS IP must be Setu-allow-listed) ---
SETU_PROVIDER=live
SETU_BASE_URL=https://dg-sandbox.setu.co
SETU_CLIENT_ID=
SETU_CLIENT_SECRET=
SETU_PRODUCT_INSTANCE_ID=
# Shared secret Setu signs webhooks with (share the receiving URL with Setu):
SETU_WEBHOOK_SECRET=change-me

# --- Cloudflare R2 ---
STORAGE_PROVIDER=r2
R2_BUCKET=mango-esign
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_REGION=auto
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
